# CFTFF Environment Configuration

# Enable encryption by default (optional)
# Can be overridden by --encryption CLI flag
# Priority: 1. CLI flag, 2. This env variable, 3. Default (false)
ENABLE_ENCRYPTION=false

# RSA encryption keys (PEM format)
# Required when encryption is enabled
# Generate with: 
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem

RSA_PUBLIC_KEY=""
RSA_PRIVATE_KEY=""

# Note: 
# - Keys should be kept secure and never committed to version control
# - The same key pair must be used for encoding and decoding
# - When encoding with encryption, RSA_PUBLIC_KEY is required
# - When decoding encrypted files, RSA_PRIVATE_KEY is required
