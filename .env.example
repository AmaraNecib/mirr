# mirr Environment Configuration
# Local-only — already in .gitignore.
#
# Generate a key pair once (RSA-2048):
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
#
# Then paste the contents of each PEM file into the variable below
# (include the BEGIN/END lines).

# Required when running `mirr encode ... --encrypt`
MIRR_PUBLIC_KEY=""

# Required when decoding a video that was encoded with --encrypt
MIRR_PRIVATE_KEY=""
