{
  "name": "cftff",
  "version": "1.0.0",
  "description": "Visual file storage system - encode any file as visual data in images/video",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "bun run src/cli.ts",
    "build": "bun build src/cli.ts --outdir=dist --target=bun",
    "start": "bun run dist/cli.js",
    "encode": "bun run src/cli.ts encode",
    "decode": "bun run src/cli.ts decode"
  },
  "keywords": [
    "visual-encoding",
    "steganography",
    "file-storage",
    "bun",
    "typescript"
  ],
  "dependencies": {
    "sharp": "^0.33.1"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.3.3"
  }
}
